{
  "retention_days": 90,
  "hardware": {
    "NVIDIA-A100": {"display_name": "NVIDIA A100"},
    "NVIDIA-H100": {"display_name": "NVIDIA H100"},
    "NVIDIA-H20": {"display_name": "NVIDIA H20"},
    "AMD-MI300X": {"display_name": "AMD MI300X"},
    "Ascend-A2": {"display_name": "Ascend NPU A2"},
    "Ascend-A3": {"display_name": "Ascend NPU A3"}
  },
  "models": {
    "Qwen-image": {
      "display_name": "Qwen Image",
      "category": "image_generation",
      "metrics": {
        "required": ["pass_rate", "latency_p99_ms", "throughput_tokens_per_sec"],
        "optional": ["e2e_latency_ms", "peak_memory_gb", "image_quality_score", "generation_time_ms"]
      },
      "alert_overrides": {}
    },
    "Qwen-Image-edit": {
      "display_name": "Qwen Image Edit",
      "category": "image_editing",
      "metrics": {
        "required": ["pass_rate", "latency_p99_ms"],
        "optional": ["e2e_latency_ms", "peak_memory_gb", "edit_quality_score", "generation_time_ms"]
      },
      "alert_overrides": {}
    },
    "WAN2.2": {
      "display_name": "WAN 2.2",
      "category": "video_generation",
      "metrics": {
        "required": ["pass_rate", "latency_p99_ms"],
        "optional": ["e2e_latency_ms", "peak_memory_gb", "video_quality_score", "generation_time_ms"]
      },
      "alert_overrides": {}
    },
    "Qwen3-Omni": {
      "display_name": "Qwen3 Omni",
      "category": "multimodal",
      "metrics": {
        "required": ["pass_rate", "latency_p99_ms", "ttft_ms", "throughput_tokens_per_sec"],
        "optional": ["tpot_ms", "ttfp_ms", "real_time_factor", "benchmark_score"]
      },
      "alert_overrides": {}
    },
    "Qwen3-TTS": {
      "display_name": "Qwen3 TTS",
      "category": "audio_synthesis",
      "metrics": {
        "required": ["pass_rate", "latency_p99_ms"],
        "optional": ["ttft_ms", "tpot_ms", "ttfp_ms", "real_time_factor", "throughput_tokens_per_sec", "audio_quality_mos", "speaker_similarity"]
      },
      "alert_overrides": {
        "latency_p99_ms_critical": 2000
      }
    }
  },
  "kanban_pages": {
    "qwen3_omni_history": {
      "source_dir": "qwen3omni",
      "filters": [
        "model_id",
        "test_name",
        "dataset_name",
        "endpoint_type",
        "backend",
        "tokenizer_id",
        "max_concurrency",
        "num_prompts"
      ],
      "table_columns": [
        "date",
        "test_name",
        "dataset_name",
        "max_concurrency",
        "num_prompts",
        "endpoint_type",
        "backend",
        "model_id",
        "request_throughput",
        "output_throughput",
        "total_token_throughput",
        "mean_ttft_ms",
        "p99_ttft_ms",
        "mean_e2el_ms",
        "mean_audio_rtf",
        "mean_audio_ttfp_ms",
        "mean_audio_duration_s"
      ],
      "metric_groups": [
        {
          "id": "throughput",
          "title": "Throughput",
          "metrics": [
            "output_throughput",
            "total_token_throughput"
          ]
        },
        {
          "id": "ttft",
          "title": "TTFT",
          "metrics": [
            "mean_ttft_ms",
            "median_ttft_ms",
            "p99_ttft_ms"
          ]
        },
        {
          "id": "tpot_itl",
          "title": "TPOT + ITL",
          "metrics": [
            "mean_tpot_ms",
            "median_tpot_ms",
            "p99_tpot_ms",
            "mean_itl_ms",
            "median_itl_ms",
            "p99_itl_ms"
          ]
        },
        {
          "id": "e2el",
          "title": "E2EL",
          "metrics": [
            "mean_e2el_ms",
            "median_e2el_ms",
            "p99_e2el_ms"
          ]
        },
        {
          "id": "audio_rtf",
          "title": "Audio RTF",
          "metrics": [
            "mean_audio_rtf",
            "median_audio_rtf",
            "p99_audio_rtf"
          ]
        },
        {
          "id": "audio_ttfp",
          "title": "Audio TTFP",
          "metrics": [
            "mean_audio_ttfp_ms",
            "median_audio_ttfp_ms",
            "p99_audio_ttfp_ms"
          ]
        },
        {
          "id": "audio_duration",
          "title": "Audio Duration",
          "metrics": [
            "mean_audio_duration_s",
            "median_audio_duration_s",
            "p99_audio_duration_s"
          ]
        }
      ]
    }
  },
  "thresholds": {
    "pass_rate_warning": 0.9,
    "pass_rate_critical": 0.8,
    "latency_p99_ms_critical": 1000,
    "crash_count_critical": 3,
    "regressions": {
      "pass_rate_drop": 0.05,
      "latency_p99_increase": 0.2,
      "ttft_increase": 0.2,
      "throughput_drop": 0.15,
      "benchmark_score_drop": 0.05
    }
  }
}
